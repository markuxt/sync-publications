{
  "name": "sync-publications-action",
  "version": "0.0.2",
  "description": "GitHub Action to sync publications from OpenAlex based on member ORCIDs",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "build": "tsup",
    "watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "echo \"Linting not configured yet\" && exit 0",
    "format": "echo \"Formatting not configured yet\" && exit 0",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "github-action",
    "openalex",
    "publications",
    "academic",
    "sync",
    "markdown",
    "research"
  ],
  "author": "hnrobert",
  "license": "Apache-2.0",
  "dependencies": {
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "unpdf": "^1.6.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markuxt/sync-publications.git"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
