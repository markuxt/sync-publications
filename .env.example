# OpenAlex Configuration
# Copy this file to .env.development (local) or .env (generic) and fill in
# your values. See README.md for details.

# ROR ID of your institution.
# Find yours at https://ror.org
ROR_ID=https://ror.org/03y4dt428

# Contact email for OpenAlex API requests.
# Required by OpenAlex's polite usage policy.
CONTACT_EMAIL=your-email@example.com

# OpenAlex API key (optional — premium tier, for higher rate limits).
# Leave empty to use the free polite pool (mailto). In GitHub Actions, pass this
# via a repository secret (OPENALEX_API_KEY) rather than committing it here.
OPENALEX_API_KEY=

# Members directory (relative to project root, or absolute).
# Member markdown with ORCIDs is scanned from here.
# Leave empty to use the default src/members.
MEMBERS_DIR=

# Publications directory (relative to project root, or absolute).
# Generated publication markdown and screenshots are written here.
# Leave empty to use the default src/publications.
PUBLICATIONS_DIR=

# GitHub Actions output file (auto-set by the runner). Leave empty locally.
GITHUB_OUTPUT=
