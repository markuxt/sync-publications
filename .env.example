# OpenAlex Configuration
# Copy this file to .env and fill in your values

# ROR ID of your institution
# Find your ROR ID at https://ror.org
ROR_ID=https://ror.org/03y4dt428

# Contact email for OpenAlex API requests
# Required by OpenAlex's polite usage policy
CONTACT_EMAIL=your-email@example.com

# Content directory path (relative to project root)
# Default is 'src'
CONTENT_DIR=src

# GitHub Actions output path (only needed when running in GitHub Actions)
# Leave empty when running locally
GITHUB_OUTPUT=
